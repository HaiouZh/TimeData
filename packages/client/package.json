{
  "name": "@timedata/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mobile": "tsc -b && vite build --mode mobile",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "vitest run --project e2e",
    "typecheck": "pnpm --filter @timedata/shared build && tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/app-launcher": "^7.0.4",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/share": "^7.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@timedata/shared": "workspace:*",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^4.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.0",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^14.0.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "catalog:",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "catalog:"
  }
}
