# 生产模式下必须设置；本地开发如需无鉴权旁路，显式设置 ALLOW_UNAUTHENTICATED_DEV=1
AUTH_TOKEN=
# ALLOW_UNAUTHENTICATED_DEV=1

# CORS 白名单，逗号分隔，不要带空格；未设置时跨域 /api/* 默认拒绝（fail-closed）
# 同时部署 Web + Android App 时，必须把网页域名和移动壳来源都列上：
#   - Web 域名：https://your-domain.example.com
#   - Android（Capacitor androidScheme: "https"）：https://localhost
#   - 兼容旧 Capacitor scheme：capacitor://localhost
# 注意：docker-compose.yml 的 environment: 块必须显式列出 `- ALLOWED_ORIGINS=${ALLOWED_ORIGINS:-}`，
# 否则就算 .env 写了，变量也进不去容器。
ALLOWED_ORIGINS=https://your-domain.example.com,https://localhost,capacitor://localhost

DB_PATH=/app/data/timedata.db
PORT=3000

# Watchtower HTTP API token；生产部署必须设置为随机长字符串。
WATCHTOWER_TOKEN=

# TimeData 镜像 tag；默认 latest，可 pin 到指定版本。
TIMEDATA_IMAGE_TAG=latest

# 镜像来源仓库，用来查最新版本（GitHub owner/repo）
UPDATE_REPO=HaiouZh/TimeData

# 可选：GitHub API Token，用于提高 /api/version 查询限额
# GITHUB_TOKEN=github_pat_xxx
