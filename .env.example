# 生产模式下必须设置；本地开发如需无鉴权旁路，显式设置 ALLOW_UNAUTHENTICATED_DEV=1
AUTH_TOKEN=
# ALLOW_UNAUTHENTICATED_DEV=1

# CORS 白名单，逗号分隔；未设置时跨域 /api/* 默认拒绝（fail-closed）
# 移动壳常见：https://localhost,capacitor://localhost
# Web：https://your-domain.example.com
ALLOWED_ORIGINS=https://your-domain.example.com

DB_PATH=/app/data/timedata.db
PORT=3000

# 服务器上 docker-compose.yml 所在的绝对路径，
# updater 容器需要这个来执行 docker compose 命令。
HOST_COMPOSE_DIR=/home/ubuntu/timedata

# 镜像来源仓库，用来查最新版本（GitHub owner/repo）
UPDATE_REPO=HaiouZh/TimeData

# 可选：GitHub API Token，用于提高 /api/version 查询限额
# GITHUB_TOKEN=github_pat_xxx
