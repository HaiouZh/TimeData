{
  "name": "timedata",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "dev:client": "pnpm --filter @timedata/client dev",
    "dev:server": "pnpm --filter @timedata/server dev",
    "build:shared": "pnpm --filter @timedata/shared build",
    "build:client": "pnpm --filter @timedata/client build",
    "build:server": "pnpm --filter @timedata/server build",
    "build:cli": "pnpm --filter @timedata/cli build",
    "build:client:fast": "pnpm build:shared && pnpm --filter @timedata/client exec vite build",
    "build:mobile": "pnpm build:shared && pnpm --filter @timedata/mobile build",
    "build:mobile:apk": "pnpm build:shared && pnpm --filter @timedata/mobile android:debug",
    "build:mobile:release-apk": "pnpm build:shared && pnpm --filter @timedata/mobile android:release",
    "build": "pnpm build:shared && pnpm -r --workspace-concurrency=3 --filter @timedata/client --filter @timedata/server --filter @timedata/cli build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=2 test && pnpm test:scripts",
    "test:client:changed": "pnpm --filter @timedata/client exec vitest run --project unit --changed",
    "test:scripts": "node --test scripts/*.test.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "check:docs": "node scripts/check-evergreen-docs.mjs",
    "check:docs:strict": "node scripts/check-evergreen-docs.mjs --mode=strict",
    "check:docs:stale": "node scripts/check-evergreen-docs.mjs --mode=stale",
    "check:docs:size": "node scripts/check-evergreen-docs.mjs --mode=size",
    "check:docs:coverage": "node scripts/check-evergreen-docs.mjs --mode=coverage",
    "check:docs:links": "node scripts/check-evergreen-docs.mjs --mode=links",
    "check:ui": "node scripts/check-no-native-controls.mjs",
    "check:test": "node scripts/check-test-hygiene.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "sharp": "^0.35.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
